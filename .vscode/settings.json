{
    // ==========================================================================
    // Python Configuration (Windows)
    // ==========================================================================

    // Use the conda environment
    // Update <username> to your Windows username
    "python.defaultInterpreterPath": "C:\\Users\\${env:USERNAME}\\miniconda3\\envs\\sports_betting\\python.exe",
    "python.condaPath": "conda",

    // Terminal activation
    "python.terminal.activateEnvironment": true,
    "python.terminal.activateEnvInCurrentTerminal": true,

    // Analysis
    "python.analysis.typeCheckingMode": "basic",
    "python.analysis.autoImportCompletions": true,
    "python.analysis.diagnosticMode": "workspace",

    // ==========================================================================
    // Formatting & Linting
    // ==========================================================================

    // Black formatter
    "[python]": {
        "editor.defaultFormatter": "ms-python.black-formatter",
        "editor.formatOnSave": true,
        "editor.codeActionsOnSave": {
            "source.organizeImports": "explicit"
        }
    },
    "black-formatter.args": [
        "--line-length=100"
    ],

    // Ruff linter (native server - faster than legacy ruff-lsp)
    "ruff.nativeServer": "on",
    "ruff.organizeImports": true,

    // ==========================================================================
    // Testing
    // ==========================================================================

    "python.testing.pytestEnabled": true,
    "python.testing.unittestEnabled": false,
    "python.testing.pytestArgs": [
        "tests",
        "-v"
    ],

    // ==========================================================================
    // Jupyter Notebooks
    // ==========================================================================

    "jupyter.askForKernelRestart": false,
    "notebook.cellToolbarLocation": {
        "default": "right"
    },
    "notebook.output.textLineLimit": 100,

    // ==========================================================================
    // Editor Settings
    // ==========================================================================

    "editor.rulers": [100],
    "editor.tabSize": 4,
    "editor.insertSpaces": true,
    "editor.trimAutoWhitespace": true,
    "editor.renderWhitespace": "trailing",

    "files.trimTrailingWhitespace": true,
    "files.insertFinalNewline": true,
    "files.trimFinalNewlines": true,

    // ==========================================================================
    // File Associations
    // ==========================================================================

    "files.associations": {
        "*.sql": "sql",
        ".env": "dotenv",
        ".env.example": "dotenv",
        "CLAUDE.md": "markdown",
        "CLAUDE-FLOW.md": "markdown"
    },

    // ==========================================================================
    // File Exclusions (hide from explorer)
    // ==========================================================================

    "files.exclude": {
        "**/__pycache__": true,
        "**/*.pyc": true,
        "**/.pytest_cache": true,
        "**/.mypy_cache": true,
        "**/.ruff_cache": true,
        "**/*.egg-info": true,
        "**/.ipynb_checkpoints": true
    },

    // Search exclusions
    "search.exclude": {
        "**/data/raw": true,
        "**/data/processed": true,
        "**/logs": true,
        "**/backups": true,
        "**/.venv": true
    },

    // ==========================================================================
    // SQLite Viewer
    // ==========================================================================

    "sqlite.defaultDatabase": "${workspaceFolder}/data/betting.db",

    // ==========================================================================
    // Terminal (Windows)
    // ==========================================================================

    "terminal.integrated.defaultProfile.windows": "Git Bash",

    // Auto-activate conda on terminal open
    "terminal.integrated.env.windows": {
        "CONDA_AUTO_ACTIVATE_BASE": "false"
    },

    // ==========================================================================
    // Markdown
    // ==========================================================================

    "[markdown]": {
        "editor.wordWrap": "on",
        "editor.quickSuggestions": {
            "other": true,
            "comments": false,
            "strings": false
        }
    },
    "markdown.preview.doubleClickToSwitchToEditor": true,

    // ==========================================================================
    // Git
    // ==========================================================================

    "git.autofetch": true,
    "git.confirmSync": false,
    "gitlens.hovers.currentLine.over": "line",

    // ==========================================================================
    // Todo Tree (highlight TODOs, FIXMEs)
    // ==========================================================================

    "todo-tree.general.tags": [
        "TODO",
        "FIXME",
        "BUG",
        "HACK",
        "XXX",
        "NOTE",
        "REVIEW"
    ],
    "todo-tree.highlights.defaultHighlight": {
        "gutterIcon": true
    },

    // ==========================================================================
    // Spell Checker
    // ==========================================================================

    "cSpell.words": [
        "NCAAB",
        "NCAAF",
        "sportsipy",
        "pybaseball",
        "nflfastR",
        "cfbd",
        "hoopR",
        "backtesting",
        "backtest",
        "Statcast",
        "moneyline",
        "sportsbook",
        "sportsbooks",
        "bankroll",
        "scipy",
        "sklearn",
        "statsmodels",
        "sqlite"
    ],
    "cSpell.ignorePaths": [
        "data/**",
        "logs/**",
        ".vscode/**",
        "requirements.txt"
    ],
    "makefile.configureOnOpen": true
}
