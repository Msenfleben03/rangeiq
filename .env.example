# Sports Betting Model Development - Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
#
# Only variables actually read from the environment are listed here.
# Bankroll, risk limits, DB paths, and rate limits are hardcoded in
# config/settings.py and config/constants.py — edit those files directly.

# =============================================================================
# ODDS DATA APIs
# =============================================================================
# The Odds API (https://the-odds-api.com/)
# Free tier: 500 credits/month — used as fallback in collect_closing_odds.py
# and as supplemental multi-book source in daily_run.py / settle_paper_bets.py.
# Without this key the pipeline falls back to ESPN Core API only (functional
# but lacks Pinnacle closing lines for accurate CLV benchmarking).
ODDS_API_KEY=your_odds_api_key_here

# =============================================================================
# SPORTS DATA APIs
# =============================================================================
# CBBData / Barttorvik T-Rank (https://www.cbbdata.com/)
# Free with registration — provides daily point-in-time efficiency ratings.
# Required for NCAAB Barttorvik feature integration (fetch_barttorvik_data.py,
# daily_run.py, barttorvik_fetcher.py).
CBBDATA_API_KEY=your_cbbdata_api_key_here

# KenPom (https://kenpom.com/)
# $25/year subscription — provides adjusted efficiency ratings.
# Used by fetch_kenpom_data.py and daily_snapshot.py.
KENPOM_EMAIL=your_kenpom_email_here
KENPOM_PASSWORD=your_kenpom_password_here

