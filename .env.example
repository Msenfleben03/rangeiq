# Sports Betting Model Development - Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# =============================================================================
# ODDS DATA APIs
# =============================================================================
# The Odds API (https://the-odds-api.com/)
# Free tier: 500 requests/month
ODDS_API_KEY=your_odds_api_key_here

# =============================================================================
# SPORTS DATA APIs
# =============================================================================
# CollegeFootballData.com API (https://collegefootballdata.com/)
# Free with registration
CFBD_API_KEY=your_cfbd_api_key_here

# Sports Reference (usually no key needed, but may need for rate limiting)
# SPORTSREF_API_KEY=

# CBBData / Barttorvik T-Rank (https://www.cbbdata.com/)
# Free with registration - provides daily point-in-time efficiency ratings
CBBDATA_API_KEY=your_cbbdata_api_key_here

# KenPom (https://kenpom.com/)
# $25/year subscription - provides adjusted efficiency ratings
KENPOM_EMAIL=your_kenpom_email_here
KENPOM_PASSWORD=your_kenpom_password_here

# =============================================================================
# DATABASE
# =============================================================================
# SQLite path (default)
DATABASE_PATH=data/betting.db

# PostgreSQL (if migrating later)
# DATABASE_URL=postgresql://user:password@localhost:5432/sports_betting

# =============================================================================
# ENVIRONMENT
# =============================================================================
# development, staging, production
ENVIRONMENT=development

# Timezone for display (storage is always UTC)
DISPLAY_TIMEZONE=America/Chicago

# =============================================================================
# LOGGING
# =============================================================================
LOG_LEVEL=INFO
LOG_FILE=logs/sports_betting.log

# =============================================================================
# BETTING CONFIGURATION
# =============================================================================
# Starting bankroll (for reference, actual tracking in database)
INITIAL_BANKROLL=5000

# Default Kelly fraction
KELLY_FRACTION=0.25

# Maximum bet as fraction of bankroll
MAX_BET_FRACTION=0.03

# =============================================================================
# SPORTSBOOK ALLOCATION (for reference)
# =============================================================================
# These are informational - actual tracking in database
DRAFTKINGS_ALLOCATION=1000
FANDUEL_ALLOCATION=1000
BETMGM_ALLOCATION=750
CAESARS_ALLOCATION=750
ESPN_BET_ALLOCATION=500
RESERVE_FUND=1000

# =============================================================================
# NOTIFICATION (Optional - for alerts)
# =============================================================================
# Email notifications
# SMTP_SERVER=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASSWORD=your_app_password
# ALERT_EMAIL=your_email@gmail.com

# Slack notifications (webhook URL)
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz

# =============================================================================
# RATE LIMITING
# =============================================================================
# Requests per minute for various APIs
SPORTSIPY_RATE_LIMIT=30
PYBASEBALL_RATE_LIMIT=60
ODDS_API_RATE_LIMIT=10

# =============================================================================
# DEVELOPMENT FLAGS
# =============================================================================
# Enable debug mode (more verbose logging)
DEBUG=false

# Use cached data instead of live API calls (for development)
USE_CACHED_DATA=false

# Paper betting mode (log bets but don't mark as live)
PAPER_BETTING_MODE=true
