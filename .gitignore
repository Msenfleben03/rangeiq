# Sports Betting Model Development - Git Ignore

# =============================================================================
# SENSITIVE DATA - NEVER COMMIT
# =============================================================================
.env
.env.local
.env.*.local
*.env
.mcp.json
secrets.yaml
secrets.json
credentials.json
api_keys.txt

# Sportsbook account information
sportsbook_accounts.txt
sportsbook_accounts.json

# =============================================================================
# DATA FILES - TOO LARGE / REPRODUCIBLE
# =============================================================================
# Raw data (can be re-downloaded)
data/raw/
data/external/

# Processed data (can be regenerated)
data/processed/
data/odds/

# Database files (tracked separately or too large)
*.db
*.sqlite
*.sqlite3
data/ncaab_betting.db

# Parquet/feather files
*.parquet
*.feather

# Large CSV/JSON data
data/**/*.csv
data/**/*.json
!data/**/*_sample.csv
!data/**/*_sample.json

# =============================================================================
# MODEL ARTIFACTS
# =============================================================================
models/saved/
models/*.pkl
models/*.joblib
models/*.h5
*.pickle
*.pkl
*.joblib

# MLflow
mlruns/

# =============================================================================
# PYTHON
# =============================================================================
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
venv/
ENV/
env/
.venv/

# Conda
*.conda
conda-meta/

# =============================================================================
# JUPYTER NOTEBOOKS
# =============================================================================
# Checkpoint files
.ipynb_checkpoints/

# Notebook output cells (optional - some prefer to commit these)
# Uncomment if you want to ignore notebook outputs:
# *.ipynb

# =============================================================================
# IDE / EDITORS
# =============================================================================
# VS Code - Track shared configs, ignore user-specific
# The .vscode/ folder contains shared workspace settings
# !.vscode/ means we DO track it (negates ignore)
!.vscode/
.vscode/*
# But DO track these shared configs:
!.vscode/settings.json
!.vscode/launch.json
!.vscode/extensions.json
!.vscode/tasks.json
# Ignore VS Code user-specific files
*.code-workspace

# PyCharm
.idea/
*.iml

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim
*.swp
*.swo
*~

# Emacs
*~
\#*\#
/.emacs.desktop
/.emacs.desktop.lock

# =============================================================================
# OS GENERATED
# =============================================================================
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
*~

# =============================================================================
# TESTING & COVERAGE
# =============================================================================
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
.pytest_cache/
coverage.xml
*.cover
*.py,cover
.hypothesis/

# =============================================================================
# LOGS
# =============================================================================
logs/
*.log
log*.txt

# =============================================================================
# TEMPORARY FILES
# =============================================================================
tmp/
temp/
*.tmp
*.temp
*.bak
*.backup
tmp*.json
temp*.json
nul

# =============================================================================
# BACKUP FOLDERS (prevents accumulation in root)
# =============================================================================
*-backup*/
*-backup-v*/
data-backup*/

# =============================================================================
# BUILD OUTPUTS
# =============================================================================
*.manifest
*.spec

# =============================================================================
# DOCUMENTATION BUILD
# =============================================================================
docs/_build/
site/

# =============================================================================
# CLAUDE CODE (tooling config — not project code)
# =============================================================================
.claude/
# Keep CLAUDE.md at project root tracked (it's outside .claude/)

# =============================================================================
# CLAUDE-FLOW (removed from project)
# =============================================================================
.claude-flow/
.swarm/

# =============================================================================
# NODE/NPM
# =============================================================================
node_modules/
package-lock.json
.npm/
.eslintcache

# =============================================================================
# ARCHIVE (track structure, not contents)
# =============================================================================
archive/*
!archive/README.md
!archive/**/README.md

# =============================================================================
# PROJECT SPECIFIC
# =============================================================================
# Backtest results (large files, regenerable)
backtests/results/
backtests/*.csv

# Performance reports (regenerable)
reports/*.html
reports/*.pdf

# Scratch/experimental files
scratch/
experiments/
sandbox/

# Vercel
.vercel/
.vercel-build/

# Personal notes (not for repo)
NOTES.md
TODO_PERSONAL.md
docs/2026-02-17-kenpom.pdf
recover-pipeline-data.txt
.worktrees/
